generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum DocumentStatus {
  PENDING
  PROCESSING
  READY
  FAILED
}

enum ChatMessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum UsageEventType {
  UPLOAD
  EMBEDDING
  CHAT
}

model User {
  id             String          @id @default(cuid())
  name           String?
  email          String          @unique
  passwordHash   String?
  authProviderId String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  knowledgeBases KnowledgeBase[]
  documents      Document[]
  chunks         DocumentChunk[]
  chatSessions   ChatSession[]
  usageLogs      UsageLog[]

  @@map("users")
}

model KnowledgeBase {
  id          String        @id @default(cuid())
  userId      String
  name        String
  description String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  documents   Document[]
  chunks      DocumentChunk[]
  chats       ChatSession[]

  @@index([userId, deletedAt])
  @@map("knowledge_bases")
}

model Document {
  id              String          @id @default(cuid())
  knowledgeBaseId String
  userId          String
  fileName        String
  fileType        String
  fileSize        Int
  storagePath     String
  status          DocumentStatus  @default(PENDING)
  errorMessage    String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase   @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks          DocumentChunk[]

  @@index([userId, knowledgeBaseId])
  @@index([knowledgeBaseId, status])
  @@map("documents")
}

model DocumentChunk {
  id              String        @id @default(cuid())
  documentId      String
  knowledgeBaseId String
  userId          String
  chunkIndex      Int
  content         String
  tokenCount      Int?
  sourcePage      Int?
  sourceTitle     String?
  embeddingJson   Json?
  createdAt       DateTime      @default(now())
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  document        Document      @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, chunkIndex])
  @@index([userId, knowledgeBaseId])
  @@index([documentId])
  @@map("document_chunks")
}

model ChatSession {
  id              String        @id @default(cuid())
  knowledgeBaseId String
  userId          String
  title           String
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  knowledgeBase   KnowledgeBase @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  messages        ChatMessage[]

  @@index([userId, knowledgeBaseId, updatedAt])
  @@map("chat_sessions")
}

model ChatMessage {
  id            String          @id @default(cuid())
  chatSessionId String
  role          ChatMessageRole
  content       String
  citationsJson Json?
  createdAt     DateTime        @default(now())
  chatSession    ChatSession     @relation(fields: [chatSessionId], references: [id], onDelete: Cascade)

  @@index([chatSessionId, createdAt])
  @@map("chat_messages")
}

model UsageLog {
  id           String         @id @default(cuid())
  userId       String
  eventType    UsageEventType
  metadataJson Json?
  createdAt    DateTime       @default(now())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("usage_logs")
}
